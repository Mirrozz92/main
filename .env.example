# =========================
# FastSub — .env.example
# Скопируй в .env и заполни значения. Реальный .env в репозиторий не коммитится.
# =========================

# --- Project ---
PROJECT_NAME=fastsub
ENV=production
DEBUG=false
LOG_LEVEL=INFO
TZ=Europe/Moscow

# --- Public API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLIC_HOST=your.public.host
API_WORKERS=4

# --- PostgreSQL ---
# Сгенерируй пароль: openssl rand -base64 32
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fastsub
POSTGRES_USER=fastsub
POSTGRES_PASSWORD=

PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432

# --- Redis ---
# Сгенерируй: openssl rand -base64 32
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_CACHE=0
REDIS_DB_TASKIQ=1
REDIS_DB_RATELIMIT=2

# --- Telegram bots ---
# Получи у @BotFather, для каждого бота отдельный
MAIN_BOT_TOKEN=          # объединённый бот (рекламодатель + паблишер)
ADMIN_BOT_TOKEN=
# JSON-массив, на старте — один бот
CHECKER_BOT_TOKENS=
# Устаревшие токены (больше не используются, оставлены для совместимости)
# ADVERTISER_BOT_TOKEN=
# PUBLISHER_BOT_TOKEN=

# --- Admins ---
# Без @, через запятую если несколько
ADMIN_USERNAMES=
# Опционально, для двойной проверки. Узнать ID: @userinfobot
ADMIN_USER_IDS=

# --- CryptoBot ---
# Получи в @CryptoBot → Crypto Pay → Create App
CRYPTOBOT_TOKEN=
CRYPTOBOT_API_URL=https://pay.crypt.bot/api
# Сгенерируй: openssl rand -hex 32
CRYPTOBOT_WEBHOOK_SECRET=

# --- Exchange rates ---
EXCHANGE_RATE_SOURCE=coingecko
EXCHANGE_RATE_CACHE_TTL_SECONDS=300

# --- Business rules ---
MIN_CAMPAIGN_TOPUP_RUB=500
MIN_PAYOUT_RUB=100
PLATFORM_COMMISSION_PERCENT=25
VIP_COMMISSION_PERCENT=20
RETENTION_BONUS_PERCENT=5
RETENTION_BONUS_THRESHOLD=90
LINK_ID_TTL_SECONDS=3600
COLD_START_HOLD_HOURS=8
COLD_START_MIN_SUBS=50
RETENTION_WINDOW_DAYS=7

# --- Subscription verification ---
SUBSCRIPTION_CHECK_INTERVAL_HOURS=4
HOLD_CHECK_INTERVAL_MINUTES=15

# --- Rate limiting ---
RATE_LIMIT_PER_SECOND=50
RATE_LIMIT_PER_MINUTE=2000

# --- Webhooks to publishers ---
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_BACKOFF_SECONDS=60

# --- Security ---
# Сгенерируй: openssl rand -hex 32
SECRET_KEY=

# --- Backups ---
BACKUP_LOCAL_DIR=/var/backups/postgres
BACKUP_LOCAL_RETENTION_HOURS=24
# IP/hostname твоего storage-сервера
BACKUP_REMOTE_HOST=
BACKUP_REMOTE_USER=backup
BACKUP_REMOTE_PATH=/backups/fastsub
BACKUP_REMOTE_SSH_KEY=/root/.ssh/backup_key
# ID канала в Telegram для бэкапов (опционально)
BACKUP_TG_CHAT_ID=

# --- Monitoring ---
PROMETHEUS_PORT=9090
SENTRY_DSN=

# --- Encryption ---
# Сгенерируй: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
